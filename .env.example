# Superuser connection (migrations / DDL).
# Used only for setup. The application MUST NOT use this.
ADMIN_DATABASE_URL=postgres://postgres:postgres@localhost:5432/rls_poc

# Application connection. The role/credentials here are something
# you will create yourself in a migration as part of the RLS design.
# Leave commented out until you've decided on the role split.
# APP_DATABASE_URL=postgres://app_user:CHANGE_ME@localhost:5432/rls_poc

PORT=3000
